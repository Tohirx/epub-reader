<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/text_view_search_result_page_number"
        app:layout_constraintTop_toTopOf="@id/text_view_search_result"
        app:layout_constraintBottom_toBottomOf="@id/text_view_search_result"
        tools:text="8"
        android:textSize="18sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <com.google.android.material.textview.MaterialTextView
        app:layout_constraintStart_toEndOf="@id/text_view_search_result_page_number"
        android:layout_marginLeft="24dp"
        android:id="@+id/text_view_search_result"
        android:layout_width="match_parent"
        tools:text="Jesus Christ Dexter Morgan"
        android:layout_height="wrap_content"/>

</androidx.constraintlayout.widget.ConstraintLayout>