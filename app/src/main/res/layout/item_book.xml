<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_margin="12dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">


        <com.google.android.material.imageview.ShapeableImageView
            tools:src="@color/md_theme_onSurface"
            app:layout_constraintTop_toTopOf="parent"
            android:id="@+id/image_view_book_cover"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Small"
            android:scaleType="centerCrop"/>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/reading_percent"
        android:textColor="?android:attr/textColorSecondary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="67%"
        android:layout_marginEnd="8dp"
        android:textSize="12sp"
        android:fontFamily="sans-serif-light"
        app:layout_constraintTop_toTopOf="@id/image_button_options"
        app:layout_constraintBottom_toBottomOf="@id/image_button_options"
        app:layout_constraintEnd_toStartOf="@id/image_button_options"/>

    <ImageButton
        app:tint="@color/md_theme_onSurface"
        android:id="@+id/image_button_options"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="@id/image_view_book_cover"
        app:layout_constraintTop_toBottomOf="@id/image_view_book_cover"
        android:src="@drawable/icon_options"/>




</androidx.constraintlayout.widget.ConstraintLayout>