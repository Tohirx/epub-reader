<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/bottom_sheet_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:clipToPadding="false">


    <TextView
        android:id="@+id/book_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:text="Book Title Here"
        android:textColor="@android:color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        android:ellipsize="end"
        android:maxLines="2"
        android:paddingBottom="4dp" />

    <!-- Book Status / Progress -->
    <TextView
        android:id="@+id/book_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="Progress: 45%"
        android:textColor="@android:color/holo_green_dark"
        android:textStyle="bold"
        android:textSize="14sp"
        android:paddingBottom="8dp" />

    <!-- Book Title -->


    <!-- Book Author -->
    <TextView
        android:id="@+id/book_author"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:text="Author Name"
        android:textColor="@android:color/darker_gray"
        android:textSize="16sp"
        android:paddingBottom="4dp" />

    <!-- Publication Year -->
    <TextView
        android:id="@+id/publication_year"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:text="Published: 2024"
        android:textColor="@android:color/darker_gray"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/number_of_pages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:text="Number of pages 350"
        android:textColor="@android:color/darker_gray"
        android:textSize="14sp" />

</LinearLayout>
