<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:padding="4dp"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/text_view_definition"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:text="The rear of the body, especially the part between the neck and the end of the spine and opposite the chest and belly." />

    <TextView
        android:id="@+id/text_view_example"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="1dp"
        android:textColor="@android:color/darker_gray"
        android:textSize="12sp"
        android:visibility="visible"
        tools:text="Could you please scratch my back?" />


</LinearLayout>