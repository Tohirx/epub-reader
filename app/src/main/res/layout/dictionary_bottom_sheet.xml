<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurface"
    android:padding="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Word + Speaker Icon -->
        <!-- Word + Speaker Icon -->
        <TextView
            android:id="@+id/text_view_word_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textStyle="bold"
            tools:text="Word"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageButton
            android:id="@+id/button_play_pronunciation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/icon_speaker"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Play pronunciation"
            android:layout_marginStart="8dp"
            android:padding="2dp"
            app:layout_constraintStart_toEndOf="@id/text_view_word_text"
            app:layout_constraintTop_toTopOf="@id/text_view_word_text"
            app:layout_constraintBottom_toBottomOf="@id/text_view_word_text" />


        <!-- Divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="?attr/colorOutline"
            app:layout_constraintTop_toBottomOf="@id/text_view_word_text"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

        <!-- Definition -->
        <TextView
            android:id="@+id/text_view_definition_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            tools:text="Definition."
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Usage Examples -->
        <TextView
            android:id="@+id/text_view_examples_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Usage example(s)."
            android:textStyle="bold"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            app:layout_constraintTop_toBottomOf="@id/text_view_definition_text"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="12dp"/>

        <LinearLayout
            android:id="@+id/examples_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/text_view_examples_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:paddingTop="4dp"
            android:paddingBottom="12dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
